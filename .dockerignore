# Keep the build context small & secrets out of the image.
.git
.gitignore
.venv
venv
__pycache__
*.pyc
.pytest_cache
tests
weights          # rebuilt inside the image by scripts/download_weights.py
.env             # never bake secrets; inject at runtime (App Runner env vars)
.env.*
!.env.example
*.md
deploy/lifeshot-intelligence.service
deploy/nginx.conf
