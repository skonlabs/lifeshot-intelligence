# =============================================================================
# LIFESHOT Intelligence API — example environment
# Copy to .env (git-ignored) and fill in. In production, load via systemd
# EnvironmentFile or a secret manager; chmod 600 the .env file.
# =============================================================================

# --- App ---
APP_ENV=development                       # development | production
LOG_LEVEL=INFO
HOST=127.0.0.1                            # bind loopback only; nginx is the public listener
PORT=8000
# Comma-separated allowed CORS origins. NEVER "*" in production.
CORS_ORIGINS=http://localhost:3000,https://app.lifeshot.ai
# Gate/disable interactive docs in prod
ENABLE_DOCS=true

# --- Auth: API keys ---
# Comma-separated. Provide EITHER plaintext keys (dev) via API_KEYS, OR
# sha256 hashes (prod) via API_KEY_HASHES "keyid:sha256hex,...". Hashes win.
API_KEYS=dev-local-key-please-change
# API_KEY_HASHES=frontend:9f86d0818...,batch:2c26b46b6...

# --- DeepFace / Face ---
DEEPFACE_HOME=./weights                    # relocate weights here (git-ignored)
FACE_MODEL=Facenet512
FACE_DETECTOR=yunet
FACE_METRIC=cosine
FACE_WARMUP=true                           # load + warm models at startup
FACE_POOL_WORKERS=2                        # threads for off-loop inference (serialized per model)

# --- OpenAI (openai imported only in common/openai_client.py) ---
# Data-handling ack: OpenAI-backed features are DISABLED unless this is true.
OPENAI_ENABLED=false
OPENAI_API_KEY=                            # from secret manager only; never commit
OPENAI_EXTRACT_MODEL=gpt-5.5              # extraction + PII text classification
OPENAI_CLASSIFY_MODEL=gpt-5.5-mini       # document-type classification (smaller/faster)
OPENAI_SCENE_MODEL=gpt-5.5-mini          # scene description
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=3
OPENAI_BASE_URL=                           # optional override (Azure/proxy/on-prem)

# --- Moderation / NSFW ---
MODERATION_PROVIDER=openai                 # openai | local
MODERATION_OPENAI_MODEL=omni-moderation-latest
NSFW_THRESHOLD=0.5
NSFW_MODEL=                                # path to local ONNX model when provider=local

# --- OCR (redaction geometry only; imported only in pii/service.py) ---
OCR_ENGINE=tesseract                       # tesseract | paddle

# --- Input hard caps (per-request bounds) ---
MAX_FILE_MB=10
MAX_MEGAPIXELS=40
MAX_PDF_PAGES=10
MAX_VERIFY_CANDIDATES=50
MAX_SCENE_PII_PAGES=5

# --- Reverse geocoding (EXIF GPS -> place name); external call, OFF by default ---
GEOCODING_ENABLED=false

# --- Backpressure / capacity ---
MAX_INFLIGHT_HEAVY=8                        # bound concurrent heavy (face/vision) work
CACHE_MAX_ITEMS=1024                        # per-worker LRU bound

# --- Cost controls (OpenAI is real money) ---
GLOBAL_SPEND_CAP_USD=50.0                   # daily global cap; fail closed on breach
PER_KEY_RATE_PER_MIN=120                    # requests/min per API key
PER_KEY_DAILY_SPEND_USD=10.0
